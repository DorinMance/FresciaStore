<section class="frescia-brand-story{% if section.settings.alt_bg %} frescia-brand-story--alt{% endif %}">
  <div class="container">
    <div class="frescia-brand-story__grid{% if section.settings.image_right %} frescia-brand-story__grid--reverse{% endif %}">

      {%- comment -%} Media {%- endcomment -%}
      <div class="frescia-brand-story__media reveal">
        <div class="frescia-brand-story__img-wrap">
          {%- if section.settings.image != blank -%}
            <img
              src="{{ section.settings.image | img_url: '800x1000', crop: 'center' }}"
              alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
              class="frescia-brand-story__img"
              loading="lazy"
              width="800" height="1000"
            >
          {%- else -%}
            <div class="frescia-brand-story__img-placeholder">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity=".4">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              <span>Adaugă imagine din Customizer</span>
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.badge_number != blank -%}
          <div class="frescia-brand-story__badge">
            <span class="frescia-brand-story__badge-num">{{ section.settings.badge_number }}</span>
            <span class="frescia-brand-story__badge-text">{{ section.settings.badge_text }}</span>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Content {%- endcomment -%}
      <div class="frescia-brand-story__content reveal reveal--delay-2">
        {%- if section.settings.eyebrow != blank -%}
          <p class="frescia-section-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="frescia-section-title">{{ section.settings.title }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="frescia-brand-story__text">{{ section.settings.text }}</p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="frescia-brand-story__features">
            {%- for block in section.blocks -%}
              <div class="frescia-brand-story__feature reveal reveal--delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
                <div class="frescia-brand-story__feature-icon">
                  {%- case block.settings.icon -%}
                    {%- when 'leaf' -%}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 8C8 10 5.9 16.17 3.82 19.34A1 1 0 002 19c1-4 4-8 8-10"/>
                        <path d="M17 8l-1-5-5 3"/>
                      </svg>
                    {%- when 'star' -%}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                      </svg>
                    {%- when 'truck' -%}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="3" width="15" height="13"/>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                        <circle cx="5.5" cy="18.5" r="2.5"/>
                        <circle cx="18.5" cy="18.5" r="2.5"/>
                      </svg>
                    {%- when 'check' -%}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    {%- when 'heart' -%}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                      </svg>
                    {%- else -%}
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 8 12 12 14 14"/>
                      </svg>
                  {%- endcase -%}
                </div>
                <div class="frescia-brand-story__feature-text">
                  <strong>{{ block.settings.title }}</strong>
                  <span>{{ block.settings.description }}</span>
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--primary">
            {{ section.settings.cta_text }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Povestea brandului",
  "tag": "section",
  "class": "frescia-brand-story-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "checkbox",
      "id": "alt_bg",
      "label": "Fundal gri deschis",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "image_right",
      "label": "Imagine dreapta (text stânga)",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagine"
    },
    {
      "type": "text",
      "id": "badge_number",
      "label": "Număr pe badge (opțional)",
      "placeholder": "ex: 500+"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Text badge",
      "placeholder": "ex: produse italiene"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Text mic deasupra",
      "default": "Povestea noastră"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titlu",
      "default": "Din inima Italiei, direct la masa ta"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Paragraf descriptiv",
      "default": "Frescia Store s-a născut din pasiunea pentru gastronomia italiană autentică. Selecționăm cu grijă fiecare produs direct de la producători artizanali din toată Italia — de la pastele din grâu dur sicilian până la uleiul de măsline extravirgin din Toscana."
    },
    {
      "type": "header",
      "content": "Buton CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Text buton",
      "placeholder": "ex: Descoperă povestea"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link buton"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Punct forte",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Iconiță",
          "options": [
            { "value": "leaf",  "label": "Frunză (natural)" },
            { "value": "star",  "label": "Stea (calitate)" },
            { "value": "truck", "label": "Camion (livrare)" },
            { "value": "check", "label": "Bifă (garanție)" },
            { "value": "heart", "label": "Inimă (pasiune)" }
          ],
          "default": "star"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titlu",
          "default": "100% Autenticitate"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descriere scurtă",
          "default": "Fiecare produs vine cu certificat de origine italian"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Povestea brandului",
      "settings": {
        "eyebrow": "Povestea noastră",
        "title": "Din inima Italiei, direct la masa ta",
        "text": "Frescia Store s-a născut din pasiunea pentru gastronomia italiană autentică. Selecționăm cu grijă fiecare produs direct de la producători artizanali din toată Italia — de la pastele din grâu dur sicilian până la uleiul de măsline extravirgin din Toscana.",
        "badge_number": "500+",
        "badge_text": "produse italiene"
      },
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "leaf",
            "title": "Ingrediente naturale",
            "description": "Fără conservanți, fără aditivi — exact cum fac italienii"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "star",
            "title": "Producători artizanali",
            "description": "Parteneriate directe cu familii de producători din Italia"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "truck",
            "title": "Livrare rapidă",
            "description": "1-3 zile lucrătoare, ambalaj protejat cu grijă"
          }
        }
      ]
    }
  ]
}
{% endschema %}
