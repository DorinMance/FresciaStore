<!-- DEBUG: path="{{ request.path }}" page_type="{{ request.page_type }}" -->
{%- if request.path == '/pages/despre-noi' -%}
  {%- section 'about-page' -%}
{%- else -%}
<div class="container" style="text-align:center;padding:100px 24px;">
  <div style="font-size:7rem;font-family:var(--font-heading);color:var(--color-primary-light);line-height:1;margin-bottom:8px;">404</div>
  <h1 style="font-family:var(--font-heading);font-size:2rem;color:var(--color-primary);margin-bottom:14px;">Pagina nu a fost găsită</h1>
  <p style="color:var(--color-text-light);margin-bottom:32px;max-width:440px;margin-left:auto;margin-right:auto;">
    Ne pare rău, pagina pe care o cauți nu există sau a fost mutată.
  </p>
  <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
    <a href="/" class="btn btn-green">Acasă</a>
    <a href="/collections/all" class="btn btn-outline" style="color:var(--color-primary);border-color:var(--color-primary);">Toate produsele</a>
  </div>
</div>
{%- endif -%}
