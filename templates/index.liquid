{%- comment -%} ── Hero Video Section ── {%- endcomment -%}
{% section 'hero-video' %}

{%- comment -%} ── Trust Bar Section ── {%- endcomment -%}
{% section 'trust-bar' %}

{%- comment -%} ── Main Homepage Layout ── {%- endcomment -%}
<div class="container">
  <div class="frescia-layout">

    {%- comment -%} Sidebar stânga — categorii dinamice din Shopify {%- endcomment -%}
    {% render 'sidebar' %}

    {%- comment -%} Conținut dreapta {%- endcomment -%}
    <div>

      {%- comment -%} ── Grid Categorii principale ── {%- endcomment -%}
      {%- assign displayable_collections = collections | where: 'handle', 'all' -%}
      {%- assign has_cats = false -%}
      {%- for col in collections -%}
        {%- unless col.handle == 'all' or col.handle == 'frontpage' -%}
          {%- assign has_cats = true -%}
          {%- break -%}
        {%- endunless -%}
      {%- endfor -%}

      {%- if has_cats -%}
        <section class="frescia-section" aria-labelledby="cats-title">
          <div class="frescia-section-header">
            <p class="frescia-section-eyebrow">Catalog</p>
            <h2 class="frescia-section-title" id="cats-title">Categorii de produse</h2>
          </div>

          <div class="frescia-cat-grid">
            {%- for collection in collections limit: 6 -%}
              {%- unless collection.handle == 'all' or collection.handle == 'frontpage' -%}
                <a href="{{ collection.url }}" class="frescia-cat-card">
                  {%- if collection.image -%}
                    <img
                      src="{{ collection.image | img_url: '600x450', crop: 'center' }}"
                      alt="{{ collection.title | escape }}"
                      class="frescia-cat-card__image"
                      loading="lazy"
                      width="600" height="450"
                    >
                  {%- else -%}
                    <div class="frescia-cat-card__placeholder"></div>
                  {%- endif -%}
                  <div class="frescia-cat-card__overlay"></div>
                  <div class="frescia-cat-card__label">
                    {{ collection.title }}
                    <div class="frescia-cat-card__count">{{ collection.products_count }} produse</div>
                  </div>
                </a>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        </section>
      {%- endif -%}

      {%- comment -%} ── Grid Produse populare (colecția frontpage) ── {%- endcomment -%}
      {%- assign featured = collections['frontpage'] -%}
      {%- if featured and featured.products_count > 0 -%}
        <section class="frescia-section" aria-labelledby="popular-title">
          <div class="frescia-grid-header">
            <div>
              <p class="frescia-section-eyebrow">Din colecție</p>
              <h2 class="frescia-section-title" id="popular-title">Produse populare</h2>
            </div>
            <a href="{{ featured.url }}" class="btn btn-outline" style="color:var(--color-primary);border-color:var(--color-primary);">
              Toate produsele
            </a>
          </div>

          <div class="frescia-product-grid">
            {%- for product in featured.products limit: 6 -%}
              <article class="frescia-card" aria-label="{{ product.title | escape }}">
                <a href="{{ product.url }}" class="frescia-card__image-wrap" tabindex="-1">
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
                      alt="{{ product.featured_image.alt | default: product.title | escape }}"
                      class="frescia-card__image"
                      loading="lazy"
                      width="600" height="600"
                    >
                  {%- else -%}
                    <div class="frescia-card__image" style="background:var(--color-primary-light);display:flex;align-items:center;justify-content:center;height:100%;">
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1" opacity=".3">
                        <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                      </svg>
                    </div>
                  {%- endif -%}

                  <div class="frescia-card__badges">
                    {%- if product.compare_at_price > product.price -%}
                      <span class="badge badge-sale">Sale</span>
                    {%- endif -%}
                    {%- if product.tags contains 'new' or product.tags contains 'nou' -%}
                      <span class="badge badge-new">Nou</span>
                    {%- endif -%}
                  </div>
                </a>

                <div class="frescia-card__body">
                  {%- if product.vendor != blank -%}
                    <p class="frescia-card__vendor">{{ product.vendor }}</p>
                  {%- endif -%}

                  <h3 class="frescia-card__title">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>

                  <div class="frescia-card__price-row">
                    <span class="frescia-card__price">{{ product.price | money }}</span>
                    {%- if product.compare_at_price > product.price -%}
                      <span class="frescia-card__compare-price">{{ product.compare_at_price | money }}</span>
                    {%- endif -%}
                  </div>

                  {%- if product.available -%}
                    <button
                      class="frescia-card__add-btn"
                      type="button"
                      data-add-to-cart
                      data-variant-id="{{ product.variants.first.id }}"
                      aria-label="{{ 'general.cart.add' | t }} {{ product.title | escape }}"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 0 1-8 0"/>
                      </svg>
                      {{ 'products.add_to_cart' | t }}
                    </button>
                  {%- else -%}
                    <button class="frescia-card__add-btn" disabled>
                      {{ 'products.sold_out' | t }}
                    </button>
                  {%- endif -%}
                </div>
              </article>
            {%- endfor -%}
          </div>
        </section>
      {%- endif -%}

    </div>{%- comment -%} /col dreapta {%- endcomment -%}
  </div>{%- comment -%} /.frescia-layout {%- endcomment -%}
</div>
