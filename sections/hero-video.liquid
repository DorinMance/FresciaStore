        <rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>
      </svg>
      <svg class="icon-play" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;">
        <polygon points="5 3 19 12 5 21 5 3"/>
      </svg>
    </button>
  {%- endif -%}

  <script>
  (function() {
    var hero = document.getElementById('frescia-hero');
    if (!hero) return;

    var SESSION_KEY = 'fh_hero_seen';
    var isReturning = document.documentElement.classList.contains('fh-returning');
    var dp = hero.querySelector('dotlottie-player');

    function lottiePause() {
      if (!dp) return;
      try {
        if (typeof dp.stop === 'function') dp.stop();
        else if (typeof dp.pause === 'function') dp.pause();
      } catch(e){}
    }
    function lottiePlayFresh() {
      if (!dp) return;
      try {
        if (typeof dp.stop === 'function') dp.stop();
        if (typeof dp.play === 'function') dp.play();
      } catch(e){}
    }
    function onLottieReady(fn) {
      if (!dp) return;
      fn();
      customElements.whenDefined('dotlottie-player').then(function() {
        fn();
        dp.addEventListener('ready', fn);
        dp.addEventListener('load', fn);
      });
    }

    function showEnded() {
      hero.classList.add('frescia-hero--ended');
      onLottieReady(lottiePlayFresh);
    }

    /* Vizitator care revine: autoplay pe dp face restul, plus play() agresiv */
    if (isReturning) {
      showEnded();
      return;
    }

    /* Vizită nouă/refresh: marchează imediat sesiunea (chiar dacă userul navighează) */
    sessionStorage.setItem(SESSION_KEY, '1');

    /* Oprește Lottie până se termină video-ul */
    onLottieReady(lottiePause);

    /* Detectează dispozitivul, rulează doar video-ul corect */
    var isMobile = window.matchMedia('(max-width: 768px)').matches;
    var primary = isMobile
      ? document.getElementById('fh-mob-video')
      : document.getElementById('hero-video');
    if (!primary || !primary.dataset.src) return;

    primary.src = primary.dataset.src;
    if (isMobile) {
      var rate = 1.45;
      primary.playbackRate = rate;
      primary.addEventListener('loadedmetadata', function() { primary.playbackRate = rate; });
    }
    primary.play().catch(function(){});

    var fallback = setTimeout(showEnded, 15000);
    primary.addEventListener('ended', function() {
      clearTimeout(fallback);
      showEnded();
    });
  })();
  </script>

</section>

