<section
  class="frescia-hero{% unless section.settings.video_url != blank %} frescia-hero--no-video{% endunless %}"
  aria-label="{{ section.settings.heading | escape }}"
  id="frescia-hero"
>

  {%- comment -%} Video background {%- endcomment -%}
  {%- if section.settings.video_url != blank -%}
    <video
      class="frescia-hero__video"
      id="hero-video"
      src="{{ section.settings.video_url }}"
      autoplay
      muted
      playsinline
      preload="none"
      aria-hidden="true"
    ></video>
  {%- elsif section.settings.fallback_image != blank -%}
    <img
      src="{{ section.settings.fallback_image | img_url: '1920x' }}"
      alt="{{ section.settings.heading | escape }}"
      class="frescia-hero__video frescia-hero__fallback-img"
    >
  {%- else -%}
    <div class="frescia-hero__video" style="background:var(--color-primary);"></div>
  {%- endif -%}

  {%- comment -%} Mobile: animație brand (ascunsă pe desktop) {%- endcomment -%}
  <div class="fh-mob-vis" aria-hidden="true">
    <!-- Ramură de măslin stânga jos -->
    <svg class="fh-branch fh-branch--l" viewBox="0 0 90 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M55 195 Q42 158 48 118 Q55 78 65 42" stroke="rgba(116,170,80,.45)" stroke-width="2" stroke-linecap="round"/>
      <ellipse cx="44" cy="116" rx="17" ry="9" transform="rotate(-38 44 116)" fill="rgba(116,170,80,.22)"/>
      <ellipse cx="57" cy="96" rx="17" ry="9" transform="rotate(22 57 96)" fill="rgba(116,170,80,.19)"/>
      <ellipse cx="43" cy="148" rx="14" ry="8" transform="rotate(-48 43 148)" fill="rgba(116,170,80,.17)"/>
      <ellipse cx="55" cy="132" rx="14" ry="8" transform="rotate(32 55 132)" fill="rgba(116,170,80,.2)"/>
      <ellipse cx="41" cy="170" rx="12" ry="7" transform="rotate(-22 41 170)" fill="rgba(116,170,80,.14)"/>
      <ellipse cx="53" cy="158" rx="12" ry="7" transform="rotate(42 53 158)" fill="rgba(116,170,80,.16)"/>
      <circle cx="67" cy="44" r="5.5" fill="rgba(116,170,80,.55)"/>
      <circle cx="74" cy="56" r="4" fill="rgba(116,170,80,.45)"/>
      <circle cx="61" cy="65" r="4.5" fill="rgba(116,170,80,.5)"/>
    </svg>
    <!-- Ramură dreapta sus (oglindită) -->
    <svg class="fh-branch fh-branch--r" viewBox="0 0 90 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M35 5 Q48 42 42 82 Q35 122 25 158" stroke="rgba(116,170,80,.35)" stroke-width="1.5" stroke-linecap="round"/>
      <ellipse cx="46" cy="84" rx="14" ry="8" transform="rotate(38 46 84)" fill="rgba(116,170,80,.16)"/>
      <ellipse cx="33" cy="104" rx="14" ry="8" transform="rotate(-22 33 104)" fill="rgba(116,170,80,.14)"/>
      <ellipse cx="47" cy="52" rx="12" ry="7" transform="rotate(48 47 52)" fill="rgba(116,170,80,.13)"/>
      <ellipse cx="35" cy="68" rx="12" ry="7" transform="rotate(-32 35 68)" fill="rgba(116,170,80,.15)"/>
      <circle cx="31" cy="8" r="4" fill="rgba(116,170,80,.4)"/>
      <circle cx="24" cy="18" r="3" fill="rgba(116,170,80,.35)"/>
    </svg>
    <!-- Cercuri decorative dreapta -->
    <div class="fh-orb fh-orb--1"></div>
    <div class="fh-orb fh-orb--2"></div>
    <!-- Puncte flotante (ingrediente) -->
    <span class="fh-dot fh-dot--a"></span>
    <span class="fh-dot fh-dot--b"></span>
    <span class="fh-dot fh-dot--c"></span>
    <span class="fh-dot fh-dot--d"></span>
    <!-- Steag italian stânga sus -->
    <div class="fh-it-corner">
      <div class="fh-it-flag"><span></span><span></span><span></span></div>
      <span class="fh-it-label">Autentic Italian</span>
    </div>
    <!-- Bandă steag dreaptă -->
    <div class="fh-flag-strip"><span></span><span></span><span></span></div>
  </div>

  {%- comment -%} Overlay — se întunecă când video-ul se termină {%- endcomment -%}
  <div
    class="frescia-hero__overlay"
    id="hero-overlay"
    style="background: rgba({{ section.settings.overlay_color | color_extract: 'red' }}, {{ section.settings.overlay_color | color_extract: 'green' }}, {{ section.settings.overlay_color | color_extract: 'blue' }}, {{ section.settings.overlay_opacity | divided_by: 100.0 }});"
  ></div>

  {%- comment -%} Conținut — ascuns până video se termină (dacă există video) {%- endcomment -%}
  <div class="frescia-hero__content" id="hero-content">
    {%- if section.settings.badge_text != blank -%}
      <div class="frescia-hero__badge">
        <span class="badge badge-italian">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;margin-right:5px;">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          {{- section.settings.badge_text -}}
        </span>
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="frescia-hero__title">{{ section.settings.heading }}</h1>
    {%- endif -%}

    <p class="frescia-hero__tagline">gusto dell'Italia</p>

    {%- if section.settings.subheading != blank -%}
      <p class="frescia-hero__subtitle">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="frescia-hero__buttons">
      {%- if section.settings.btn1_text != blank -%}
        <a href="{{ section.settings.btn1_url | default: '/collections/all' }}" class="btn btn-primary">
          {{ section.settings.btn1_text }}
        </a>
      {%- endif -%}

      {%- if section.settings.btn2_text != blank -%}
        <a href="{{ section.settings.btn2_url | default: '/pages/despre-noi' }}" class="btn btn-outline">
          {{ section.settings.btn2_text }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Buton play/pause (vizibil doar după ce apare conținutul) {%- endcomment -%}
  {%- if section.settings.video_url != blank -%}
    <button
      class="frescia-hero__play-btn"
      id="hero-play-btn"
      aria-label="{{ 'general.accessibility.pause_video' | t }}"
      type="button"
      style="display:none;"
    >
      <svg class="icon-pause" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>
      </svg>
      <svg class="icon-play" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;">
        <polygon points="5 3 19 12 5 21 5 3"/>
      </svg>
    </button>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Hero Video",
  "tag": "section",
  "class": "frescia-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL video (mp4)",
      "info": "1. Mergi în Shopify Admin → Settings → Files → Upload file → încarcă fișierul .mp4. 2. Click pe fișierul încărcat → copiază URL-ul. 3. Lipește URL-ul aici."
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Imagine fallback (dacă nu ai video)"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Culoare overlay",
      "default": "#1a4a2e"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacitate overlay initial (%)",
      "min": 10,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "header",
      "content": "Conținut (apare după video)"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Text badge",
      "default": "Autentic Italian"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Titlu principal",
      "default": "Savoarea Italiei la ușa ta"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtitlu",
      "default": "Produse italiene autentice — de la paste și uleiuri, la dulciuri și gust tradițional."
    },
    {
      "type": "header",
      "content": "Butoane"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Buton primar — text",
      "default": "Descoperă produsele"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Buton primar — link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Buton secundar — text",
      "default": "Povestea noastră"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Buton secundar — link"
    }
  ],
  "presets": [
    {
      "name": "Hero Video",
      "settings": {
        "badge_text": "Autentic Italian",
        "heading": "Savoarea Italiei la ușa ta",
        "subheading": "Produse italiene autentice — de la paste și uleiuri, la dulciuri și gust tradițional.",
        "btn1_text": "Descoperă produsele",
        "btn2_text": "Povestea noastră",
        "overlay_opacity": 40
      }
    }
  ]
}
{% endschema %}
