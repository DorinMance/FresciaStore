<div class="container" style="padding-top:32px;padding-bottom:64px;">

  {%- comment -%} Breadcrumb {%- endcomment -%}
  <nav aria-label="Breadcrumb" style="margin-bottom:24px;font-size:.83rem;color:var(--color-text-light);">
    <a href="/" style="color:var(--color-text-light);">Acasă</a>
    <span style="margin:0 8px;">/</span>
    {%- if collection -%}
      <a href="{{ collection.url }}" style="color:var(--color-text-light);">{{ collection.title }}</a>
      <span style="margin:0 8px;">/</span>
    {%- endif -%}
    <span style="color:var(--color-text);">{{ product.title }}</span>
  </nav>

  {%- comment -%} ── 2-column layout ── {%- endcomment -%}
  <div class="frescia-product-page">

    {%- comment -%} Imagini stânga {%- endcomment -%}
    <div class="frescia-product-page__gallery">
      <div class="frescia-product-page__main-img" id="main-product-img">
        {%- if product.featured_image -%}
          <img
            id="product-main-image"
            src="{{ product.featured_image | img_url: '800x800', crop: 'center' }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="800" height="800"
            style="width:100%;height:auto;border-radius:var(--radius-lg);border:1px solid var(--color-border);"
          >
        {%- else -%}
          <div style="aspect-ratio:1;background:var(--color-primary-light);border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center;">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1" opacity=".3">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="frescia-product-page__thumbs">
          {%- for image in product.images limit: 6 -%}
            <button
              type="button"
              class="frescia-product-page__thumb{% if forloop.first %} is-active{% endif %}"
              onclick="document.getElementById('product-main-image').src='{{ image | img_url: '800x800', crop: 'center' }}';document.querySelectorAll('.frescia-product-page__thumb').forEach(t=>t.classList.remove('is-active'));this.classList.add('is-active');"
            >
              <img
                src="{{ image | img_url: '150x150', crop: 'center' }}"
                alt="{{ image.alt | default: product.title | escape }}"
                width="150" height="150"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Info dreapta {%- endcomment -%}
    <div class="frescia-product-page__info">

      {%- if product.vendor != blank -%}
        <p style="font-size:.78rem;text-transform:uppercase;letter-spacing:1px;color:var(--color-accent);font-weight:700;margin-bottom:8px;">{{ product.vendor }}</p>
      {%- endif -%}

      <h1 style="font-family:var(--font-heading);font-size:clamp(1.5rem,3vw,2rem);color:var(--color-primary);margin-bottom:16px;">{{ product.title }}</h1>

      {%- comment -%} Preț {%- endcomment -%}
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
        <span style="font-size:1.6rem;font-weight:700;color:var(--color-primary);" id="product-price">
          {{ product.price | money }}
        </span>
        {%- if product.compare_at_price > product.price -%}
          <span style="font-size:1.1rem;color:var(--color-text-light);text-decoration:line-through;">
            {{ product.compare_at_price | money }}
          </span>
          {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
          <span class="badge badge-sale">-{{ discount }}%</span>
        {%- endif -%}
      </div>

      {%- comment -%} Form add to cart {%- endcomment -%}
      {%- form 'product', product, id: 'product-form', data-product-form: '' -%}
        <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- if product.variants.size > 1 -%}
          <div style="margin-bottom:20px;">
            {%- for option in product.options_with_values -%}
              <div style="margin-bottom:14px;">
                <label style="display:block;font-size:.85rem;font-weight:600;margin-bottom:8px;">{{ option.name }}</label>
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                  {%- for value in option.values -%}
                    <label style="cursor:pointer;">
                      <input
                        type="radio"
                        name="option_{{ forloop.parentloop.index }}"
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}checked{% endif %}
                        style="display:none;"
                        class="product-option-input"
                        data-option-index="{{ forloop.parentloop.index0 }}"
                      >
                      <span style="display:inline-block;padding:8px 16px;border:1.5px solid var(--color-border);border-radius:var(--radius-md);font-size:.88rem;transition:all var(--transition);" class="option-btn">
                        {{ value }}
                      </span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} Cantitate {%- endcomment -%}
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
          <label style="font-size:.85rem;font-weight:600;">Cantitate</label>
          <div style="display:flex;align-items:center;border:1.5px solid var(--color-border);border-radius:var(--radius-md);overflow:hidden;">
            <button type="button" onclick="const q=document.getElementById('qty');if(q.value>1)q.value=parseInt(q.value)-1;" style="width:38px;height:38px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;background:var(--color-bg-alt);transition:background var(--transition);">−</button>
            <input type="number" name="quantity" id="qty" value="1" min="1" style="width:50px;height:38px;text-align:center;border:none;border-left:1.5px solid var(--color-border);border-right:1.5px solid var(--color-border);font-size:.95rem;">
            <button type="button" onclick="const q=document.getElementById('qty');q.value=parseInt(q.value)+1;" style="width:38px;height:38px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;background:var(--color-bg-alt);transition:background var(--transition);">+</button>
          </div>
        </div>

        {%- if product.available -%}
          <button
            type="submit"
            class="btn btn-green"
            style="width:100%;padding:16px;font-size:1rem;margin-bottom:12px;"
            data-add-to-cart
            data-variant-id="{{ product.variants.first.id }}"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            {{ 'products.add_to_cart' | t }}
          </button>
        {%- else -%}
          <button type="button" class="btn" style="width:100%;padding:16px;background:var(--color-text-light);color:#fff;font-size:1rem;cursor:not-allowed;margin-bottom:12px;" disabled>
            {{ 'products.sold_out' | t }}
          </button>
        {%- endif -%}

      {%- endform -%}

      {%- comment -%} Descriere {%- endcomment -%}
      {%- if product.description != blank -%}
        <div style="margin-top:28px;padding-top:28px;border-top:1px solid var(--color-border);">
          <h2 style="font-family:var(--font-heading);font-size:1.1rem;color:var(--color-primary);margin-bottom:14px;">Descriere produs</h2>
          <div style="font-size:.92rem;line-height:1.8;color:var(--color-text);">
            {{ product.description }}
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%} ── Produse asociate ── {%- endcomment -%}
  {%- if collection and collection.products.size > 1 -%}
    <div style="margin-top:64px;">
      <h2 style="font-family:var(--font-heading);font-size:1.6rem;color:var(--color-primary);margin-bottom:24px;">Mai din colecția {{ collection.title }}</h2>
      <div class="frescia-product-grid">
        {%- for related in collection.products limit: 4 -%}
          {%- unless related.id == product.id -%}
            <article class="frescia-card">
              <a href="{{ related.url }}" class="frescia-card__image-wrap">
                {%- if related.featured_image -%}
                  <img src="{{ related.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ related.title | escape }}" class="frescia-card__image" loading="lazy" width="600" height="600">
                {%- endif -%}
                {%- if related.compare_at_price > related.price -%}
                  <div class="frescia-card__badges"><span class="badge badge-sale">Sale</span></div>
                {%- endif -%}
              </a>
              <div class="frescia-card__body">
                <h3 class="frescia-card__title"><a href="{{ related.url }}">{{ related.title }}</a></h3>
                <div class="frescia-card__price-row">
                  <span class="frescia-card__price">{{ related.price | money }}</span>
                  {%- if related.compare_at_price > related.price -%}
                    <span class="frescia-card__compare-price">{{ related.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
                {%- if related.available -%}
                  <button class="frescia-card__add-btn" type="button" data-add-to-cart data-variant-id="{{ related.variants.first.id }}">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    {{ 'products.add_to_cart' | t }}
                  </button>
                {%- else -%}
                  <button class="frescia-card__add-btn" disabled>{{ 'products.sold_out' | t }}</button>
                {%- endif -%}
              </div>
            </article>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>
