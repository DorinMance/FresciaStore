{%- comment -%} Pre-check returning visitor BEFORE video elements parse {%- endcomment -%}
<script>
  (function() {
    var SESSION_KEY = 'fh_hero_seen';
    var navEntry = (performance.getEntriesByType('navigation') || [])[0];
    var isReload = navEntry && navEntry.type === 'reload';
    if (isReload) sessionStorage.removeItem(SESSION_KEY);
    if (!isReload && sessionStorage.getItem(SESSION_KEY)) {
      document.documentElement.classList.add('fh-returning');
    }
  })();
</script>

{%- comment -%} Preload Lottie file în paralel cu video — gata când e nevoie {%- endcomment -%}
<link rel="preload" href="https://lottie.host/3c7aa575-9dce-4930-a65b-45c53ab820e1/Bp97Y27C0A.lottie" as="fetch" crossorigin="anonymous">

<script type="module">
  import 'https://cdn.jsdelivr.net/npm/@dotlottie/player-component@2.7.12/+esm';
</script>

<section
  class="frescia-hero{% unless section.settings.video_url != blank %} frescia-hero--no-video{% endunless %}"
  aria-label="{{ section.settings.heading | escape }}"
  id="frescia-hero"
>
  {%- comment -%} Video background — src setat prin JS doar pentru vizitatori noi {%- endcomment -%}
  {%- if section.settings.video_url != blank -%}
    <video
      class="frescia-hero__video"
      id="hero-video"
      data-src="{{ section.settings.video_url }}"
      muted
      playsinline
      preload="none"
      aria-hidden="true"
    ></video>
  {%- elsif section.settings.fallback_image != blank -%}
    <img
      src="{{ section.settings.fallback_image | img_url: '1920x' }}"
      alt="{{ section.settings.heading | escape }}"
      class="frescia-hero__video frescia-hero__fallback-img"
    >
  {%- else -%}
    <div class="frescia-hero__video" style="background:var(--color-primary);"></div>
