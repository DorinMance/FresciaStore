<div class="container" style="padding-top:40px;padding-bottom:64px;">

  <h1 style="font-family:var(--font-heading);font-size:2rem;color:var(--color-primary);margin-bottom:8px;">Rezultate căutare</h1>

  <form action="/search" method="get" style="margin-bottom:32px;display:flex;gap:0;max-width:500px;">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="Caută produse..."
      style="flex:1;padding:12px 16px;border:1.5px solid var(--color-border);border-radius:var(--radius-md) 0 0 var(--radius-md);font-size:.95rem;border-right:none;outline:none;"
    >
    <button type="submit" class="btn btn-green" style="border-radius:0 var(--radius-md) var(--radius-md) 0;padding:12px 20px;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      <p style="color:var(--color-text-light);margin-bottom:24px;font-size:.9rem;">
        {{ search.results_count }} rezultate pentru <strong>"{{ search.terms }}"</strong>
      </p>
      <div class="frescia-product-grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            <article class="frescia-card">
              <a href="{{ item.url }}" class="frescia-card__image-wrap">
                {%- if item.featured_image -%}
                  <img src="{{ item.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ item.title | escape }}" class="frescia-card__image" loading="lazy" width="600" height="600">
                {%- endif -%}
                {%- if item.compare_at_price > item.price -%}
                  <div class="frescia-card__badges"><span class="badge badge-sale">Sale</span></div>
                {%- endif -%}
              </a>
              <div class="frescia-card__body">
                <h2 class="frescia-card__title"><a href="{{ item.url }}">{{ item.title }}</a></h2>
                <div class="frescia-card__price-row">
                  <span class="frescia-card__price">{{ item.price | money }}</span>
                  {%- if item.compare_at_price > item.price -%}
                    <span class="frescia-card__compare-price">{{ item.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
                {%- if item.available -%}
                  <button class="frescia-card__add-btn" type="button" data-add-to-cart data-variant-id="{{ item.variants.first.id }}">
                    {{ 'products.add_to_cart' | t }}
                  </button>
                {%- else -%}
                  <button class="frescia-card__add-btn" disabled>{{ 'products.sold_out' | t }}</button>
                {%- endif -%}
              </div>
            </article>
          {%- else -%}
            <a href="{{ item.url }}" style="display:block;padding:20px;background:var(--color-white);border:1px solid var(--color-border);border-radius:var(--radius-lg);">
              <h3 style="font-family:var(--font-heading);font-size:1rem;color:var(--color-primary);margin-bottom:4px;">{{ item.title }}</h3>
              {%- if item.content != blank -%}
                <p style="font-size:.83rem;color:var(--color-text-light);">{{ item.content | strip_html | truncate: 100 }}</p>
              {%- endif -%}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div style="text-align:center;padding:60px 24px;">
        <p style="font-size:1.1rem;color:var(--color-text-light);">
          Niciun rezultat pentru <strong>"{{ search.terms }}"</strong>
        </p>
        <a href="/collections/all" class="btn btn-green" style="margin-top:20px;">Toate produsele</a>
      </div>
    {%- endif -%}
  {%- endif -%}

</div>
